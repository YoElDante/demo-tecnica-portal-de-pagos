#!/usr/bin/env node

/**
 * Module dependencies.
 */

const debug = require('debug')('minimo-sql:server');
const http = require('http');
require('dotenv').config();
const app = require('../app');
const { sequelize } = require('../models/model.index.js');
const IS_PRODUCTION = process.env.NODE_ENV === 'production';

/**
 * Get port from environment and store in Express.
 */

const port = normalizePort(process.env.PORT || '4000');
app.set('port', port);

/**
 * Create HTTP server.
 */

const server = http.createServer(app);

/**
 * Verificar conexión a base de datos y luego iniciar servidor
 */

async function startServer() {
  try {
    // Verificar conexión a la base de datos
    await sequelize.authenticate();
    console.log('✅ Conectado exitosamente a Azure SQL Database');

    // Opcional: Sincronizar modelos (NO usar en producción)
    // await sequelize.sync({ alter: false });

    // Iniciar servidor
    server.listen(port);
    server.on('error', onError);
    server.on('listening', onListening);

  } catch (error) {
    const errorCode = error?.original?.code || error?.parent?.code || error?.code;
    if (IS_PRODUCTION) {
      // En producción evitamos filtrar detalles sensibles de infraestructura.
      console.error('❌ Error de infraestructura al iniciar la aplicación.');
      console.error(`   Código: ${errorCode || 'UNKNOWN'}`);
    } else {
      console.error('❌ Error al conectar con la base de datos:', error?.message || error);

      if (errorCode === 'ELOGIN') {
        console.error('🔐 Diagnóstico: credenciales inválidas o desactualizadas (DB_USER/DB_PASS).');
        console.error('   Acción sugerida: verificar credenciales en .env local o App Service Configuration en producción.');
      } else if (errorCode === 'ESOCKET' || errorCode === 'ETIMEOUT') {
        console.error('🌐 Diagnóstico: problema de red/firewall hacia Azure SQL.');
        console.error('   Acción sugerida: validar reglas de firewall y conectividad desde el entorno de ejecución.');
      }
    }

    process.exit(1);
  }
}

// Iniciar el servidor
startServer();

/**
 * Normalize a port into a number, string, or false.
 */

function normalizePort(val) {
  const port = parseInt(val, 10);

  if (isNaN(port)) {
    // named pipe
    return val;
  }

  if (port >= 0) {
    // port number
    return port;
  }

  return false;
}

/**
 * Event listener for HTTP server "error" event.
 */

function onError(error) {
  if (error.syscall !== 'listen') {
    throw error;
  }

  const bind = typeof port === 'string'
    ? 'Pipe ' + port
    : 'Port ' + port;

  // handle specific listen errors with friendly messages
  switch (error.code) {
    case 'EACCES':
      console.error(bind + ' requires elevated privileges');
      process.exit(1);
      break;
    case 'EADDRINUSE':
      console.error(bind + ' is already in use');
      process.exit(1);
      break;
    default:
      throw error;
  }
}

/**
 * Event listener for HTTP server "listening" event.
 */

function onListening() {
  const addr = server.address();
  const bind = typeof addr === 'string'
    ? 'pipe ' + addr
    : 'port ' + addr.port;

  console.log(`🚀 Servidor corriendo en http://localhost:${port}`);
  console.log(`📊 API disponible en http://localhost:${port}/api`);
  debug('Listening on ' + bind);
}