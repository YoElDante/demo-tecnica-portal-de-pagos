<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="icon" type="image/x-icon" href="<%= municipalidad.logos.favicon %>">
  <link rel="stylesheet" href="/stylesheets/styles.css">
  <title><%= title %> - Portal de Pagos</title>
  <style>
    /* ============================================
       BLOQUE: .result
       Resultado de operación de pago
       ============================================ */
    .result {
      max-width: 600px;
      margin: 2rem auto;
      padding: 2rem;
      background: white;
      border-radius: 12px;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
      text-align: center;
    }

    /* Modificador: Resultado exitoso */
    .result--success {
      border-top: 5px solid #28a745;
    }

    .result__icon {
      font-size: 4rem;
      margin-bottom: 1rem;
    }

    .result__title {
      font-size: 1.8rem;
      color: #28a745;
      margin-bottom: 0.5rem;
    }

    .result__subtitle {
      color: #666;
      margin-bottom: 2rem;
    }

    /* Elemento: Información del pago */
    .result__info {
      background: #f8f9fa;
      padding: 1.5rem;
      border-radius: 8px;
      margin: 1.5rem 0;
      text-align: left;
    }

    .result__info-row {
      margin: 0.5rem 0;
      display: flex;
      justify-content: space-between;
    }

    .result__info-label {
      color: #333;
      font-weight: bold;
    }

    .result__info-value {
      color: #666;
      font-family: monospace;
    }

    .result__info-value--success {
      color: #28a745;
      font-weight: bold;
    }

    .result__concept-list {
      display: flex;
      flex-direction: column;
      gap: 0.9rem;
    }

    .result__concept-card {
      border: 1px solid #dfe3e8;
      border-radius: 8px;
      padding: 0.9rem 1rem;
      background: #fff;
    }

    .result__concept-head {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      align-items: baseline;
      margin-bottom: 0.45rem;
    }

    .result__concept-title {
      font-weight: bold;
      color: #222;
    }

    .result__concept-total {
      font-weight: bold;
      color: #28a745;
      white-space: nowrap;
    }

    .result__concept-meta {
      color: #666;
      font-size: 0.92rem;
      margin: 0.2rem 0;
      line-height: 1.4;
    }

    .result__concept-breakdown {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
      gap: 0.4rem 1rem;
      margin-top: 0.7rem;
      padding-top: 0.7rem;
      border-top: 1px dashed #d9dee3;
      font-size: 0.92rem;
    }

    .result__concept-breakdown strong {
      color: #333;
    }

    /* Elemento: Sección de email */
    .result__email {
      background: #e8f5e9;
      padding: 1.5rem;
      border-radius: 8px;
      margin: 1.5rem 0;
      text-align: left;
    }

    .result__email-title {
      color: #2e7d32;
      margin-bottom: 1rem;
    }

    .result__email-form {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .result__email-input {
      padding: 0.8rem;
      border: 1px solid #c8e6c9;
      border-radius: 6px;
      font-size: 1rem;
    }

    .result__checkbox {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .result__checkbox input[type="checkbox"] {
      width: 18px;
      height: 18px;
    }

    /* Elemento: Botón de email */
    .result__btn--email {
      background: #28a745;
      color: white;
      border: none;
      padding: 0.8rem 1.5rem;
      border-radius: 6px;
      cursor: pointer;
      font-size: 1rem;
      transition: background 0.3s;
    }

    .result__btn--email:hover {
      background: #218838;
    }

    /* Elemento: Acciones */
    .result__actions {
      display: flex;
      gap: 1rem;
      justify-content: center;
      margin-top: 2rem;
      flex-wrap: wrap;
    }

    .result__btn--back {
      background: #19a8b6;
      color: white;
      text-decoration: none;
      padding: 0.8rem 1.5rem;
      border-radius: 6px;
      transition: background 0.3s;
    }

    .result__btn--back:hover {
      background: #148a96;
    }

    .result__btn--print {
      background: #6c757d;
      color: white;
      border: none;
      padding: 0.8rem 1.5rem;
      border-radius: 6px;
      cursor: pointer;
      font-size: 1rem;
      transition: background 0.3s;
      text-decoration: none;
    }

    .result__btn--print:hover {
      background: #545b62;
    }

    @media print {

      .result__email,
      .result__actions,
      .whatsapp-float {
        display: none !important;
      }

      body {
        background: white;
      }

      .result {
        box-shadow: none;
        border: 1px solid #ddd;
      }
    }
  </style>
</head>

<body>
  <!-- Header -->
  <header class="header">
    <div class="header__logo">
      <img src="<%= municipalidad.logos.web %>" alt="Logo <%= municipalidad.nombre %>" class="header__logo-img">
    </div>
    <div class="header__title">
      <h2>Portal de Pago<br><%= municipalidad.nombreCompleto %></h2>
    </div>
    <div class="header__icon">
      <img src="/images/common/alcaldiaLogo.webp" alt="Logo Alcald+IA" class="header__icon-img">
    </div>
  </header>

  <!-- Contenido Principal -->
  <main class="main main--result">
    <div class="page-bars page-bars--left">
      <div class="page-bar"></div>
      <div class="page-bar"></div>
      <div class="page-bar"></div>
      <div class="page-bar"></div>
    </div>
    <div class="page-bars page-bars--right">
      <div class="page-bar"></div>
      <div class="page-bar"></div>
      <div class="page-bar"></div>
      <div class="page-bar"></div>
    </div>
    <div class="page-dots page-dots--tl"></div>
    <div class="page-dots page-dots--br"></div>
    <div class="page-circle page-circle--1"></div>
    <div class="page-circle page-circle--2"></div>
    <% if (typeof is_demo !== 'undefined' && is_demo) { %>
    <div style="background:#fff3cd;border:2px solid #f9a825;border-radius:10px;padding:0.9rem 1.25rem;max-width:600px;margin:1.5rem auto 0;text-align:center;font-size:0.92rem;color:#856404;font-weight:500;">
      🧪 <strong>MODO DEMOSTRACIÓN</strong> — Esta operación no modificó deudas reales en la base de datos.
    </div>
    <% } %>
    <section class="result result--success">
      <div class="result__icon">✅</div>
      <h1 class="result__title">¡Pago Exitoso!</h1>
      <p class="result__subtitle">Tu pago ha sido procesado correctamente</p>

      <div class="result__info">
        <p class="result__info-row">
          <span class="result__info-label">Referencia gateway:</span>
          <span class="result__info-value"><%= external_reference %></span>
        </p>
        <p class="result__info-row">
          <span class="result__info-label">Ticket:</span>
          <span class="result__info-value"><%= ticket_number || 'N/A' %></span>
        </p>
        <p class="result__info-row">
          <span class="result__info-label">ID de operación:</span>
          <span class="result__info-value"><%= payment_id %></span>
        </p>
        <p class="result__info-row">
          <span class="result__info-label">Monto total:</span>
          <span class="result__info-value">$ <%= monto_total_display || Number(monto_total || 0).toLocaleString('es-AR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></span>
        </p>
        <p class="result__info-row">
          <span class="result__info-label">Estado:</span>
          <span class="result__info-value result__info-value--success">Aprobado</span>
        </p>
      </div>

      <% if (Array.isArray(conceptos) && conceptos.length > 0) { %>
      <div class="result__info">
        <p class="result__info-label">Conceptos del ticket</p>
        <div class="result__concept-list">
          <% conceptos.forEach((concepto) => { %>
          <article class="result__concept-card">
            <div class="result__concept-head">
              <span class="result__concept-title"><%= concepto.descripcionCompleta || concepto.detalle || concepto.tipoDescripcion || 'Concepto municipal' %></span>
              <span class="result__concept-total">$ <%= concepto.total %></span>
            </div>
            <p class="result__concept-meta">
              <strong>Bien:</strong> <%= concepto.idBien || '-' %>
              &nbsp;|&nbsp;
              <strong>Año:</strong> <%= concepto.anio || '-' %>
              &nbsp;|&nbsp;
              <strong>Cuota:</strong> <%= concepto.cuota || '-' %>
              &nbsp;|&nbsp;
              <strong>Período:</strong> <%= concepto.periodo || '-' %>
            </p>
            <p class="result__concept-meta">
              <strong>Vencimiento:</strong> <%= concepto.fechaVto || '-' %>
            </p>
            <div class="result__concept-breakdown">
              <span><strong>Importe:</strong> $ <%= concepto.importe %></span>
              <span><strong>Int/Dto:</strong> $ <%= concepto.interes %></span>
              <span><strong>Total:</strong> $ <%= concepto.total %></span>
            </div>
          </article>
          <% }) %>
        </div>
      </div>
      <% } %>

      <div class="result__actions">
        <a href="/pagos/comprobante?ref=<%= encodeURIComponent(external_reference) %>" target="_blank" rel="noopener noreferrer" class="result__btn--print">
          📄 Descargar comprobante
        </a>
        <a href="/" class="result__btn--back">🏠 Volver al inicio</a>
      </div>
    </section>
  </main>

  <!-- Footer -->
  <footer class="footer">
    <p class="footer__text">&copy; Power by Alcald+IA. Todos los derechos reservados.</p>
  </footer>

  <%- include('../partials/whatsapp-button') %>
</body>

</html>