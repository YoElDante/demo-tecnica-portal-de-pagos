# ============================================================
# PORTAL DE PAGOS MUNICIPAL — Variables de entorno
# ============================================================
# Copiar este archivo como .env en la raíz del proyecto.
# NUNCA commitear el .env real — está en .gitignore.
#
# Para desarrollo por municipio usar los scripts de npm:
#   npm run dev:elmanzano
#   npm run dev:tinoco
#   npm run dev:sanjose
#   npm run dev:calchinoeste
#   npm run dev:demo
# ============================================================


# ============================================================
# SERVIDOR
# ============================================================

# Entorno de ejecución. Controla niveles de log, debug, TLS, etc.
# Valores: development | production
NODE_ENV=development

# Puerto en el que escucha el servidor Express.
# Azure App Service ignora este valor y usa el suyo propio.
PORT=4000

# Zona horaria para cálculos de fecha (vencimientos, tickets, logs).
# Usar zona IANA. Ejemplo para Argentina: America/Argentina/Cordoba
APP_TIMEZONE=America/Argentina/Cordoba


# ============================================================
# MUNICIPIO
# ============================================================

# Identificador del municipio activo.
# Controla: qué archivo de config visual se carga Y el municipio_id
# que se envía al gateway en cada request de pago.
# Valores disponibles: elmanzano | tinoco | sanjosedelassalinas | calchinoeste | demo
MUNICIPIO=tinoco

# ID que el gateway usa para identificar a este municipio.
# Generalmente el mismo valor que MUNICIPIO.
# Solo difiere si el gateway tiene otro nombre para el municipio.
MUNICIPIO_ID=tinoco

# Solo se usa cuando MUNICIPIO=demo.
# Permite cargar el branding visual de otro municipio sin cambiar
# las credenciales de BD ni el municipio_id que ve el gateway.
# Ejemplo: MUNICIPIO=demo + DEMO_MUNICIPIO=calchinoeste →
#   BD y gateway = "demo", branding visual = Calchín Oeste
# DEMO_MUNICIPIO=calchinoeste


# ============================================================
# BASE DE DATOS (Azure SQL Server)
# ============================================================

# Servidor de base de datos. Formato Azure: <nombre>.database.windows.net
DB_HOST=XXXXXXXXXX.database.windows.net

# Nombre de la base de datos
DB_NAME=nombre_de_la_base_de_datos

# Usuario con permisos de lectura/escritura sobre DB_NAME
DB_USER=UsuarioAdmin

# Contraseña del usuario de base de datos
DB_PASS=contraseña_segura

# Puerto SQL Server. Azure SQL usa 1433 por defecto.
DB_PORT=1433

# Dialecto ORM. No cambiar: el proyecto usa Azure SQL Server.
DB_DIALECT=mssql


# ============================================================
# CONFIGURACIÓN DE NEGOCIO
# ============================================================

# Tasa de interés anual para cálculo de mora (%).
# Puede diferir por municipio — setear según el convenio municipal.
TASA_INTERES_ANUAL=40


# ============================================================
# PASARELA DE PAGOS
# ============================================================

# Pasarela de pago activa.
# Valores disponibles: siro
# Valores futuros planificados: pagotic | macropay
PAYMENT_GATEWAY=siro

# URL base del API Gateway de pagos (proyecto api-gateway-pagos).
# Desarrollo local: http://localhost:3000
# Producción Azure: https://gateway.alcaldia.com.ar
# Con ngrok: https://[tu-id].ngrok-free.app
API_GATEWAY_URL=http://localhost:3000

# URL pública de este portal, usada por el gateway para construir
# las URLs de callback (webhook) y redirect al contribuyente.
# Desarrollo local: http://localhost:4000
# Producción Azure: https://<municipio>.alcaldia.com.ar
# Con ngrok: https://[tu-id-frontend].ngrok-free.app
FRONTEND_PUBLIC_URL=http://localhost:4000


# ============================================================
# SEGURIDAD — Comunicación con el gateway
# ============================================================

# Secreto compartido con el gateway para verificar los JWT
# de los webhooks entrantes (POST /api/webhook/pago).
# La clave efectiva de firma rota diariamente: WEBHOOK_SECRET + YYYY-MM-DD
# DEBE ser idéntico al WEBHOOK_SECRET del proyecto api-gateway-pagos.
# Mínimo 32 caracteres aleatorios. Nunca exponer en logs ni en la UI.
GATEWAY_WEBHOOK_SECRET=generar_con_openssl_rand_hex_32

# Alias de GATEWAY_WEBHOOK_SECRET para compatibilidad interna.
# Debe tener el mismo valor que GATEWAY_WEBHOOK_SECRET.
WEBHOOK_SECRET=generar_con_openssl_rand_hex_32

# Secreto dedicado para el intercambio de redirect-code server-to-server.
# Cuando el contribuyente vuelve del gateway con ?code=..., el portal
# llama a POST {API_GATEWAY_URL}/api/pagos/redirect/exchange autenticado
# con este secreto para obtener el resultado del pago sin exponer JWT en la URL.
# DEBE ser idéntico al GATEWAY_REDIRECT_EXCHANGE_SECRET del api-gateway-pagos.
# Debe ser DISTINTO al GATEWAY_WEBHOOK_SECRET — son dos superficies separadas.
# Mínimo 32 caracteres aleatorios.
GATEWAY_REDIRECT_EXCHANGE_SECRET=generar_con_openssl_rand_hex_32_diferente


# ============================================================
# MANTENIMIENTO DE TICKETS
# ============================================================

# Habilitar el proceso automático de mantenimiento de tickets.
# En producción: true. En tests o entornos sin BD: false.
TICKETS_MAINTENANCE_ENABLED=true

# Cada cuántos minutos el cron marca tickets vencidos como EXPIRADO.
# Se aplica a tickets en estado PENDIENTE que superaron el tiempo de vida.
TICKETS_EXPIRE_INTERVAL_MINUTES=15

# Cada cuántas horas se ejecuta la purga física de tickets resueltos.
TICKETS_PURGE_INTERVAL_HOURS=24

# Cuántos días se retienen tickets resueltos (APROBADO/RECHAZADO/EXPIRADO)
# antes de purgarlos de la BD. Mínimo recomendado para conciliación: 30.
TICKETS_PURGE_RETENTION_DAYS=45

# Si es true, la purga SOLO loguea lo que borraría sin eliminar nada.
# Pasar a false solo cuando se haya validado que la purga es correcta.
TICKETS_PURGE_DRY_RUN=true


# ============================================================
# LOGGING
# ============================================================

# Nivel de detalle de los logs.
# development usa "trace" por defecto si no se define.
# production usa "info" por defecto si no se define.
# Valores: error | warn | info | debug | trace
# LOG_LEVEL=info


# ============================================================
# DEBUG (solo desarrollo)
# ============================================================

# Si es true, loguea detalles del flujo de redirect (code, token, exchange).
# En production se fuerza a false por código aunque esté seteado a true.
# PAYMENT_REDIRECT_DEBUG=true
