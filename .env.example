# ============================================
# CONFIGURACIÓN DEL SERVIDOR
# ============================================
# Entorno: development, test, production
NODE_ENV=development

# Puerto del servidor web
PORT=4000

# ============================================
# BASE DE DATOS (Azure SQL Server)
# ============================================
DB_HOST=XXXXXXXXXX.database.windows.net
DB_NAME=XXXXXXXXXXXXXX
DB_USER=XXXXXAdmin
DB_PASS=XXXXX-XXXX-XXXXX-$$-XXXXXXX
DB_DIALECT=mssql
DB_PORT=1433

# ============================================
# IDENTIFICACIÓN DEL MUNICIPIO
# ============================================
# Municipio activo - controla BD y configuración
# Valores disponibles: elmanzano, sanjosedelassalinas, tinoco
MUNICIPIO=tinoco

# ID para API Gateway (opcional, usa MUNICIPIO si no está definido)
MUNICIPIO_ID=tinoco

# ============================================
# CONFIGURACIÓN DE NEGOCIO
# ============================================
# Tasa de interés anual para cálculo de mora (%)
# Cada municipio puede tener su propia tasa
TASA_INTERES_ANUAL=40

# ============================================
# PASARELA DE PAGOS
# ============================================
# Gateway activo: mercadopago (default)
# Opciones futuras: pagotic, siro, macropay
PAYMENT_GATEWAY=mercadopago

# URL del API Gateway de pagos
# Desarrollo local:
API_GATEWAY_URL=http://localhost:3000

# En desarrollo con ngrok (descomentar y actualizar):
# API_GATEWAY_URL=https://[tu-url].ngrok-free.app

# ============================================
# URL PÚBLICA DEL FRONTEND (para callbacks)
# ============================================
# Desarrollo local
FRONTEND_PUBLIC_URL=http://localhost:4000

# En desarrollo con ngrok (descomentar y actualizar):
# FRONTEND_PUBLIC_URL=https://[tu-url-frontend].ngrok-free.app

# ============================================
# SEGURIDAD
# ============================================
# Secreto para validar webhooks de pagos
# IMPORTANTE: Generar un valor seguro para producción
WEBHOOK_SECRET=cambiar_por_secreto_seguro_en_produccion

# ============================================
# LOGGING (opcional)
# ============================================
# Nivel de log: debug, info, warn, error
LOG_LEVEL=info
