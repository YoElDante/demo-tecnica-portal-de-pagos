{
  "name": "portal-de-pagos-municipal",
  "version": "1.0.0",
  "private": true,
  "description": "Portal de Pagos Municipal - Sistema multi-ambiente para consulta de deudas y procesamiento de pagos",
  "main": "bin/www",
  "scripts": {
    "start": "node ./bin/www",
    "dev": "node --watch ./bin/www",
    "dev:demo": "cp envs/.env.demo .env && npm run dev",
    "dev:elmanzano": "cp envs/.env.elmanzano .env && npm run dev",
    "dev:tinoco": "cp envs/.env.tinoco .env && npm run dev",
    "dev:sanjose": "cp envs/.env.sanjosedelassalinas .env && npm run dev",
    "dev:calchinoeste": "cp envs/.env.calchinoeste .env && npm run dev",
    "testDB": "node ./tests/connection.db.test.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/YoElDante/demo-tecnica-portal-de-pagos.git"
  },
  "keywords": [
    "portal",
    "pagos",
    "municipal",
    "express",
    "sequelize",
    "azure",
    "mssql"
  ],
  "author": "Dante Delprato <dantedelprato@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/YoElDante/demo-tecnica-portal-de-pagos/issues"
  },
  "homepage": "https://github.com/YoElDante/demo-tecnica-portal-de-pagos#readme",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "axios": "1.13.2",
    "cookie-parser": "1.4.4",
    "debug": "2.6.9",
    "dotenv": "17.2.3",
    "ejs": "3.1.10",
    "express": "4.21.2",
    "express-rate-limit": "8.2.1",
    "express-validator": "7.3.0",
    "http-errors": "1.6.3",
    "jsonwebtoken": "9.0.2",
    "morgan": "1.10.1",
    "sequelize": "6.37.7",
    "tedious": "18.6.1"
  }
}