<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="icon" type="image/x-icon" href="<%= municipalidad.logos.favicon %>">

  <!-- Fuentes Google (consistentes con sitio oficial ALCALD+IA) -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@500;700&family=Open+Sans:wght@300;400;600&display=swap" rel="stylesheet">

  <!-- Estilos principales del portal -->
  <link rel="stylesheet" href="/stylesheets/styles.css">
  <!-- Estilos del componente Ticket (independiente) -->
  <link rel="stylesheet" href="/stylesheets/ticket.css">

  <!-- Librería para generación de PDF vectorial -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>

  <script src="/javascripts/deudas.js" defer></script>
  <script src="/javascripts/index.js" defer></script>
  <title><%= title %> - <%= municipalidad.nombre %></title>
</head>

<body>
  <!-- ============================================
       HEADER
       ============================================ -->
  <header class="header">
    <div class="header__logo">
      <img src="<%= municipalidad.logos.web %>" alt="Logo <%= municipalidad.nombre %>" class="header__logo-img">
    </div>
    <div class="header__title">
      <h2>Portal de Pago<br><%= municipalidad.nombreCompleto %></h2>
    </div>
    <div class="header__icon">
      <img src="/images/common/alcaldiaLogo.webp" alt="Logo Alcald+IA" class="header__icon-img">
    </div>
  </header>

  <!-- ============================================
       CONTENIDO PRINCIPAL
       ============================================ -->
  <main class="main">

    <% if (demoModoHabilitado) { %>
    <div class="demo-info" id="demo-info-card">

      <div class="demo-info__header">
        <div class="demo-info__title-row">
          <span class="demo-info__badge">🧪</span>
          <span class="demo-info__title">Portal de Demostración — Alcald+IA</span>
        </div>
        <button type="button" class="demo-info__toggle" id="demo-info-toggle" aria-label="Ocultar información">
          <span id="demo-info-toggle-icon">▲</span>
        </button>
      </div>

      <div class="demo-info__body" id="demo-info-body">
        <div class="demo-info__columns">

          <div class="demo-info__col">
            <p class="demo-info__col-title">¿Para qué sirve este portal?</p>
            <ul class="demo-info__list">
              <li>Demostraciones comerciales y presentaciones a municipios</li>
              <li>Evaluación técnica del sistema antes de la implementación</li>
              <li>Capacitación de equipos municipales</li>
              <li>Pruebas de integración con las pasarelas de pago (SIRO, MercadoPago)</li>
              <li>Validación de flujos y casos de uso reales</li>
            </ul>
          </div>

          <div class="demo-info__col">
            <p class="demo-info__col-title">Funcionalidades disponibles</p>
            <ul class="demo-info__list">
              <li><strong>Contribuyentes de ejemplo</strong> pre-cargados bajo el campo de búsqueda</li>
              <li><strong>Simulación de resultados</strong>: aprobado, pendiente, rechazado y error — sin procesar pagos reales</li>
              <li><strong>Modo BD protegida</strong>: procesa el cobro en la pasarela sin modificar deudas reales</li>
              <li><strong>Modo BD modificable</strong> (con contraseña): demuestra la sincronización real entre el portal y el sistema municipal</li>
            </ul>
          </div>

        </div>

        <div class="demo-info__footer">
          <span class="demo-info__footer-icon">⚠️</span>
          <span>Los datos mostrados son de demostración y no corresponden a un municipio real. Para implementar el sistema en su municipio, contacte al equipo de <strong>Alcald+IA</strong>.</span>
        </div>
      </div>

    </div>
    <% } %>

    <!-- Formulario de búsqueda -->
    <section class="form">
      <h1 class="form__title">Sistema de Pago Online</h1>
      <br>
      <h2 class="form__subtitle">Datos del Contribuyente</h2>

      <form action="/buscar" method="POST" class="form__content" id="form-buscar">
        <div class="form__group">
          <label for="dni" class="form__label">DNI (7-10 dígitos)</label>
          <div class="form__input-wrapper">
            <input type="text" id="dni" name="dni" pattern="\d{7,10}" minlength="7" maxlength="10" title="El DNI debe tener entre 7 y 10 números" placeholder="Ingrese su número de DNI" value="<%= typeof dni !== 'undefined' ? dni : '' %>" required oninput="this.value = this.value.replace(/[^0-9]/g, '')" class="form__input">
            <button type="submit" class="btn btn--search">Buscar</button>
          </div>
          <% if (typeof mensaje !== 'undefined' && mensaje) { %>
          <span class="form__error"><%= mensaje %></span>
          <% } %>
          <% if (demoModoHabilitado && typeof sugerenciasDemo !== 'undefined' && sugerenciasDemo.length > 0) { %>
          <div class="demo-sugerencias">
            <span class="demo-sugerencias__label">Contribuyentes de ejemplo:</span>
            <div class="demo-sugerencias__chips">
              <% sugerenciasDemo.forEach(function(s) { %>
              <button type="button" class="demo-sugerencias__chip" onclick="seleccionarContribuyente('<%= s.dni %>')">
                <span class="demo-sugerencias__chip-dni"><%= s.dni %></span>
                <span class="demo-sugerencias__chip-nombre"><%= s.nombre %></span>
              </button>
              <% }); %>
            </div>
          </div>
          <% } %>
        </div>

        <div class="form__group">
          <label for="nombre" class="form__label">Nombre Completo</label>
          <input type="text" id="nombre" name="nombre" value="<%= clienteNoEncontrado ? 'Contribuyente no encontrado' : (cliente ? (cliente.Nombre + ' ' + cliente.Apellido) : '') %>" placeholder="Nombre del contribuyente" class="form__input <%= clienteNoEncontrado ? 'form__input--not-found' : '' %>" readonly>
        </div>
      </form>
    </section>

    <!-- Tabla de deudas -->
    <% if (typeof deudas !== 'undefined') { %>
    <section class="deudas">
      <h2 class="deudas__title">Detalle de Boletas</h2>
      <p class="deudas__subtitle">Seleccione los conceptos a abonar:</p>

      <% const creditosFavor = (deudas || []).filter((d) => Number(d.Total || 0) < 0); %>
      <% const totalCreditoFavor = creditosFavor.reduce((acc, item) => acc + Number(item.Total || 0), 0); %>

      <% if (creditosFavor.length > 0) { %>
      <div class="credito-resumen" data-total-credito="<%= totalCreditoFavor %>">
        <h3 class="credito-resumen__title">Crédito a favor detectado</h3>
        <p class="credito-resumen__text">
          Se detectaron <strong><%= creditosFavor.length %></strong> movimientos a favor por
          <strong>$ <%= Math.abs(totalCreditoFavor).toLocaleString('es-AR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></strong>.
          Estos créditos se informan y se aplican al neto, pero no se envían como conceptos de cobro.
        </p>
      </div>
      <% } %>

      <% const TIPO_DESCRIPCIONES = typeof tipoDescripciones !== 'undefined' ? tipoDescripciones : {}; %>
      <% const TIPO_ICONOS = typeof tipoIconos !== 'undefined' ? tipoIconos : {}; %>

      <div class="deudas__filter">
        <label for="filtro-tipo" class="deudas__filter-label">Filtrar por Tipo:</label>
        <% if ((tiposDeuda || []).length === 0) { %>
        <small class="deudas__filter-empty">No hay tipos diferenciados en esta búsqueda.</small>
        <% } %>
        <select id="filtro-tipo" class="deudas__filter-select">
          <option value="">Todas</option>
          <% (tiposDeuda || []).forEach(t => { %>
          <option value="<%= t %>"><%= TIPO_ICONOS[t] %> <%= TIPO_DESCRIPCIONES[t] || t %></option>
          <% }) %>
        </select>
      </div>

      <div id="resumen-deudas" class="deudas__summary">
        Deudas: <span id="contador-deudas-total"><%= (deudas || []).length %></span> |
        Seleccionadas: <span id="contador-deudas-seleccionadas"><%= (deudas || []).length %></span>
      </div>

      <div class="deudas__wrapper">
        <table class="deudas__table">
          <thead>
            <tr class="deudas__row--select-all">
              <th style="text-align: center;">
                <input type="checkbox" id="checkbox-todos" class="deudas__checkbox" checked>
              </th>
              <th colspan="8" style="text-align: left; padding-left: 1rem;">
                <label for="checkbox-todos">
                  Seleccionar/Deseleccionar Todo
                </label>
              </th>
            </tr>
            <tr>
              <th style="width: 50px;">Elija</th>
              <th>Fecha Vto</th>
              <th>Detalle</th>
              <th>ID_BIEN</th>
              <th>Cuota</th>
              <th>Año</th>
              <th>Importe H.</th>
              <th>Int/Dto</th>
              <th>Total</th>
            </tr>
          </thead>

          <tbody>
            <% if ((deudas || []).length === 0) { %>
            <tr>
              <td colspan="9" class="deudas__empty">No tiene deudas pendientes.</td>
            </tr>
            <% } %>
            <% (deudas || []).forEach((deuda, index) => { %>
            <% const esCreditoFavor = Number(deuda.Total || 0) < 0; %>
            <tr data-tipo="<%= deuda.Tipo %>" data-idtrans="<%= deuda.IdTrans %>" data-total-deuda="<%= deuda.Total %>" class="<%= esCreditoFavor ? 'deudas__row--credito' : '' %>">
              <td style="text-align: center;">
                <input type="checkbox" class="deudas__checkbox" data-total="<%= deuda.Total %>" data-idtrans="<%= deuda.IdTrans %>" <%= esCreditoFavor ? 'disabled' : 'checked' %>>
              </td>
              <td>
                <%= deuda.FechaVto
                  ? new Intl.DateTimeFormat('es-AR', {
                    timeZone: process.env.APP_TIMEZONE || 'America/Argentina/Cordoba',
                    day: '2-digit',
                    month: '2-digit',
                    year: 'numeric'
                  }).format(new Date(deuda.FechaVto))
                  : '-' %>
              </td>
              <td>
                <%= deuda.Detalle || '-' %>
                <% if (esCreditoFavor) { %>
                <span class="deudas__badge-credito">CRÉDITO A FAVOR</span>
                <% } %>
              </td>
              <td><%= deuda.IdBien || '-' %></td>
              <td><%= deuda.Cuota || '-' %></td>
              <td><%= deuda.Anio || '-' %></td>
              <td>$ <%= deuda.Importe.toLocaleString('es-AR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></td>
              <td class="<%= deuda.Interes >= 0 ? 'deudas__value--interest' : 'deudas__value--discount' %>">
                <%= deuda.Interes < 0 ? '-' : '' %>$ <%= Math.abs(deuda.Interes).toLocaleString('es-AR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %>
              </td>
              <td>$ <%= deuda.Total.toLocaleString('es-AR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></td>
            </tr>
            <% }) %>
          </tbody>

          <tfoot>
            <tr class="deudas__row--total">
              <td colspan="8" style="text-align: right;"><strong>Total neto a pagar:</strong></td>
              <td><strong id="total-final" class="deudas__total">$ <%= totalGeneral ? totalGeneral.toLocaleString('es-AR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) : '0,00' %></strong></td>
            </tr>
          </tfoot>
        </table>
      </div>
    </section>
    <% } %>

    <!-- Panel de Demostración (solo visible en municipio DEMO) -->
    <% if (typeof demoModoHabilitado !== 'undefined' && demoModoHabilitado && deudas && deudas.length > 0) { %>
    <%- include('partials/demo-panel') %>
    <% } %>

    <!-- Botones de acción -->
    <% if (deudas && deudas.length > 0) { %>
    <section class="actions">
      <button class="btn btn--ticket btn--generate" id="btn-generar-ticket">
        📄 Generar Ticket
      </button>
      <button class="btn btn--ticket btn--download" id="btn-descargar-pdf" disabled>
        💾 Descargar PDF
      </button>
      <button class="btn btn--qr" id="btn-ir-a-pagar" onclick="iniciarPago()">
        💳 Ir a Pagar
      </button>
    </section>

    <!-- Contenedor para preview del ticket -->
    <div id="ticket-preview-container" style="display: none;">
      <!-- El ticket se cargará aquí dinámicamente -->
    </div>

    <!-- Botones de acción POST-TICKET (aparecen después de generar el ticket) -->
    <section class="actions actions--bottom" id="ticket-actions-bottom" style="display: none;">
      <button class="btn btn--ticket btn--download" id="btn-descargar-pdf-bottom">
        💾 Descargar PDF
      </button>
      <button class="btn btn--qr" id="btn-ir-a-pagar-bottom" onclick="iniciarPago()">
        💳 Ir a Pagar
      </button>
      <button class="btn btn--ticket btn--back" id="btn-volver-arriba" onclick="volverArriba()">
        ⬆️ Volver Arriba
      </button>
    </section>
    <% } %>

    <!-- Contenedor de estado de pago (loading) -->
    <div class="qr" id="qr-container" style="display:none;">
      <p id="pago-loading" class="qr__loading">⏳ Procesando pago, por favor espere...</p>
    </div>

    <!-- Botón Generar QR (se oculta después de generarlo) -->
    <% if (deudas && deudas.length > 0 && false) { %>
    <section class="actions">
      <button class="btn btn--qr" id="generate-qr-old" onclick="mostrarQR()">Generar QR</button>
    </section>
    <% } %>
  </main>

  <%- include('partials/whatsapp-button') %>

  <script>
    const contribuyenteData = {
      codigo: '<%= cliente ? cliente.Codigo : "" %>',
      dni: '<%= cliente ? (cliente.DOCUMENTO || "").trim() : "" %>',
      nombre: '<%= cliente ? (cliente.Nombre + " " + cliente.Apellido).trim() : "" %>',
      email: '<%= cliente ? (cliente.Email || "") : "" %>'
    };
  </script>


  <!-- ============================================
       FOOTER
       ============================================ -->
  <footer class="footer">
    <p class="footer__text">&copy; Power by Alcald+IA. Todos los derechos reservados.</p>
    <p>🌐 <a href="https://www.alcaldia.com.ar" target="_blank">www.alcaldia.com.ar</a></p>
  </footer>

</body>

</html>